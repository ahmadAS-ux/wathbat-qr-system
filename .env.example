# ── API server ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Base URL embedded in every generated QR code.
# Set to your frontend URL + /scan, e.g. https://yourapp.onrender.com/scan
# Falls back to /scan (relative) if not set.
QR_SCAN_BASE_URL=https://yourapp.onrender.com/scan

# Pino log level: trace | debug | info | warn | error  (default: info)
LOG_LEVEL=info

# ── Frontend (set in Render dashboard before build, then redeploy) ────────────
# Full URL of the API service — baked into the JS bundle at build time.
# Leave empty to use relative paths (only works when API and frontend share the same origin).
VITE_API_URL=https://your-api.onrender.com

# Vite base path for the static site. Required — build throws without it.
BASE_PATH=/
